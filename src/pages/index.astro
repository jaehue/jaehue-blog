---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 10);
---

<BaseLayout title="장재휴">
  <section class="mt-8 mb-16">
    <p class="text-2xl leading-relaxed tracking-tight">
    공부하는 유목민
    </p>
  </section>

  <section>
    <h2 class="text-xs font-medium text-(--color-text-muted) uppercase tracking-widest mb-8">최근 글</h2>
    <ul class="space-y-4">
      {posts.map((post) => {
        const date = new Date(post.data.date).toLocaleDateString('ko-KR', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <li>
            <a href={`/post/${post.id}`} class="group block border border-(--color-border) rounded-lg p-5 bg-(--color-surface) hover:border-(--color-text-muted) transition-colors">
              <h3 class="text-base font-medium leading-snug">
                {post.data.title}
              </h3>
              {post.data.description && (
                <p class="text-sm text-(--color-text-muted) mt-1.5 leading-relaxed line-clamp-1">{post.data.description}</p>
              )}
              <time class="text-sm text-(--color-text-muted) mt-2 block">{date}</time>
            </a>
          </li>
        );
      })}
    </ul>
    <div class="mt-10">
      <a href="/post" class="text-sm text-(--color-text-muted) hover:text-(--color-text) transition-colors">
        모든 글 보기 →
      </a>
    </div>
  </section>
</BaseLayout>
