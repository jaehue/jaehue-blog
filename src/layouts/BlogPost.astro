---
import BaseLayout from './BaseLayout.astro';
import Comments from '../components/Comments.tsx';

interface Props {
  title: string;
  description?: string;
  date: string;
  categories?: string[];
  tags?: string[];
  postSlug?: string;
}

const { title, description, date, categories = [], tags = [], postSlug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="mt-6">
    <header class="mb-10 pb-8 border-b border-(--color-border)">
      <h1 class="text-[2rem] font-bold leading-snug tracking-tight mb-3">{title}</h1>
      <div class="flex items-center gap-3 text-sm text-(--color-text-muted)">
        <time>{formattedDate}</time>
        {categories.length > 0 && (
          <>
            <span class="text-(--color-border)">·</span>
            {categories.map((cat, i) => (
              <>
                <a href={`/categories/${encodeURIComponent(cat)}`} class="hover:text-(--color-text) transition-colors">
                  {cat}
                </a>
                {i < categories.length - 1 && <span>,</span>}
              </>
            ))}
          </>
        )}
      </div>
    </header>

    <div class="blog-content">
      <slot />
    </div>

    {tags.length > 0 && (
      <div class="mt-16 pt-8 border-t border-(--color-border)">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}`}
              class="text-[13px] px-2.5 py-1 bg-(--color-surface) rounded-full
                     text-(--color-text-muted) hover:text-(--color-text) hover:bg-(--color-border) transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    )}

    {postSlug && <Comments postSlug={postSlug} client:visible />}
  </article>
</BaseLayout>

<style is:global>
  .blog-content {
    font-size: 1rem;
    line-height: 1.8;
    color: #1a1a1a;
  }

  .blog-content p {
    margin-top: 0;
    margin-bottom: 1.75em;
  }

  .blog-content h1 {
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.3;
    margin-top: 2.5em;
    margin-bottom: 0.8em;
    letter-spacing: -0.02em;
  }

  .blog-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.35;
    margin-top: 2.5em;
    margin-bottom: 0.8em;
    padding-bottom: 0.4em;
    border-bottom: 1px solid #e5e5e3;
    letter-spacing: -0.02em;
  }

  .blog-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.4;
    margin-top: 2em;
    margin-bottom: 0.6em;
    letter-spacing: -0.01em;
  }

  .blog-content h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .blog-content blockquote {
    font-style: normal;
    border-left: 3px solid #e5e5e3;
    padding-left: 1.25em;
    margin: 2em 0;
    color: #555;
  }

  .blog-content blockquote p {
    margin-bottom: 0.75em;
  }

  .blog-content img {
    border-radius: 0.375rem;
    margin: 2em auto;
    max-width: 100%;
    height: auto;
    display: block;
  }

  .blog-content a {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: #93c5fd;
  }

  .blog-content a:hover {
    text-decoration-color: #2563eb;
  }

  .blog-content hr {
    border: none;
    border-top: 1px solid #e5e5e3;
    margin: 3em 0;
  }

  .blog-content code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: #f4f4f2;
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-weight: 400;
  }

  .blog-content pre {
    background: #f4f4f2;
    border: 1px solid #e5e5e3;
    border-radius: 0.5rem;
    padding: 1.25em 1.5em;
    overflow-x: auto;
    margin: 2em 0;
  }

  .blog-content pre code {
    background: none;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: #1a1a1a;
    font-weight: 400;
  }

  .blog-content ul, .blog-content ol {
    margin: 1.25em 0;
    padding-left: 1.75em;
  }

  .blog-content li {
    margin-bottom: 0.5em;
    line-height: 1.85;
  }

  .blog-content strong {
    font-weight: 700;
  }

  .blog-content table {
    width: 100%;
    margin: 2em 0;
    font-size: 0.9em;
  }

  .blog-content th {
    font-weight: 600;
    border-bottom: 2px solid #e5e5e3;
    padding: 0.5em 1em;
    text-align: left;
  }

  .blog-content td {
    border-bottom: 1px solid #e5e5e3;
    padding: 0.5em 1em;
  }
</style>
