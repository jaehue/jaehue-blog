---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '장재휴의 글' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/post', label: '글' },
  { href: '/essays', label: '에세이집' },
  { href: '/tags', label: '태그' },
  { href: '/about', label: '소개' },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5W55HRRRFM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5W55HRRRFM');
    </script>
    <title>{title}</title>
  </head>
  <body class="bg-(--color-bg) text-(--color-text) font-sans antialiased min-h-screen flex flex-col">
    <div class="max-w-[640px] w-full mx-auto px-5 flex-1 flex flex-col">
      <header class="py-10">
        <nav class="flex items-center justify-between">
          <a href="/" class="text-xl font-semibold tracking-tight hover:opacity-60 transition-opacity">
            장재휴
          </a>
          <div class="flex gap-5 text-sm text-(--color-text-muted)">
            {navItems.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  'hover:text-(--color-text) transition-colors',
                  currentPath.startsWith(href) && 'text-(--color-text) font-medium',
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </nav>
      </header>

      <main class="flex-1 pb-16">
        <slot />
      </main>

      <footer class="py-8 border-t border-(--color-border)">
        <p class="text-sm text-(--color-text-muted)">© {new Date().getFullYear()} 장재휴</p>
      </footer>
    </div>
  </body>
</html>
